{
  "rules": [
    {
      "id": "RULE-001",
      "pattern": "failed login|authentication failed|login failed",
      "issue": "Failed login attempt detected",
      "severity": "medium",
      "weight": 5,
      "description": "Detects failed login attempts in logs"
    },
    {
      "id": "RULE-002",
      "pattern": "unauthorized access|permission denied|access denied",
      "issue": "Unauthorized access attempt",
      "severity": "high",
      "weight": 10,
      "description": "Detects unauthorized access attempts"
    },
    {
      "id": "RULE-003",
      "pattern": "sql injection|xpath injection|code injection",
      "issue": "Possible injection attack",
      "severity": "high",
      "weight": 15,
      "description": "Detects potential injection attacks"
    },
    {
      "id": "RULE-004",
      "pattern": "api[_-]?key|secret[_-]?key|access[_-]?token",
      "issue": "API key or secret exposed",
      "severity": "high",
      "weight": 20,
      "description": "Detects exposed API keys or secrets"
    },
    {
      "id": "RULE-005",
      "pattern": "root access|sudo:|su -",
      "issue": "Privileged access detected",
      "severity": "medium",
      "weight": 8,
      "description": "Detects privileged access usage"
    },
    {
      "id": "RULE-006",
      "pattern": "port scan|nmap|masscan",
      "issue": "Port scanning activity",
      "severity": "high",
      "weight": 15,
      "description": "Detects port scanning activities"
    },
    {
      "id": "RULE-007",
      "pattern": "ddos|denial of service|flood",
      "issue": "Possible DDoS activity",
      "severity": "high",
      "weight": 20,
      "description": "Detects potential DDoS attacks"
    },
    {
      "id": "RULE-008",
      "pattern": "malware|virus|trojan|ransomware",
      "issue": "Malware reference detected",
      "severity": "high",
      "weight": 20,
      "description": "Detects malware-related references"
    },
    {
      "id": "RULE-009",
      "pattern": "bruteforce|brute force|dictionary attack",
      "issue": "Brute force attack detected",
      "severity": "high",
      "weight": 15,
      "description": "Detects brute force attack patterns"
    },
    {
      "id": "RULE-010",
      "pattern": "suspicious|anomaly|unusual",
      "issue": "Suspicious activity detected",
      "severity": "medium",
      "weight": 5,
      "description": "Detects suspicious or anomalous activities"
    }
  ],
  "thresholds": {
    "high": 25,
    "medium": 10,
    "low": 0
  },
  "bruteforce_threshold": 5
}
